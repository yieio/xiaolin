---
import SEO from "@components/SEO.astro";
import Footer from "@components/Footer.astro";
import Analytics from "@components/Analytics.astro";
import CookieConsent from "@components/CookieConsent.astro";
import "@styles/global.css";

export interface Props {
  lang: "en" | "zh";
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  lang,
  title,
  description,
  ogImage,
  canonicalURL,
} = Astro.props;

// @ts-ignore
const siteUrl = import.meta.env.PUBLIC_SITE_URL || "http://localhost:4321";
const currentPath = Astro.url.pathname;

const GTM_ID = import.meta.env.PUBLIC_GTM_ID; // 填入 GTM-P46NX9DJ
---

<!doctype html>
<html lang={lang === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="referrer" content="no-referrer" />

    <SEO
      lang={lang}
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalURL={canonicalURL ?? `${siteUrl}${currentPath}`}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {GTM_ID && (
      <script is:inline define:vars={{ GTM_ID }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer', GTM_ID);
      </script>
    )}
  </head>
  <body>
    {GTM_ID && (
      <noscript>
        <iframe 
          src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
          height="0" 
          width="0" 
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}

    <div id="app">
      <header class="header" id="site-header">
        <div class="header-inner">
          <a href={`/${lang}/`} class="header-link">
            <div class="header-brand">
              {lang === "zh" ? "小林漫画" : "Xiaolin Comics"}
            </div>
            <div class="header-subtitle">
              {lang === "zh" ? "生活漫画馆" : "Life Comic Gallery"}
            </div>
          </a>

          <div class="header-actions">
            <a href={`/${lang}/search/`} class="header-icon-btn" title={lang === "zh" ? "搜索" : "Search"}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
              </svg>
            </a>
            <a href={`/${lang}/about/`} class="header-link-btn desktop-only">
              {lang === "zh" ? "关于" : "About"}
            </a>
            <div class="lang-switch">
              <a
                href={currentPath.replace(/^\/zh/, "/en")}
                hreflang="en"
                class={`lang-btn ${lang === 'en' ? 'active' : ''}`}>EN</a>
              <a
                href={currentPath.replace(/^\/en/, "/zh")}
                hreflang="zh"
                class={`lang-btn ${lang === 'zh' ? 'active' : ''}`}>中文</a>
            </div>
            <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label={lang === "zh" ? "菜单" : "Menu"}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
                <path d="M3 12h18M3 6h18M3 18h18"></path>
              </svg>
            </button>
          </div>
        </div>
      </header>

      <div class="overlay-backdrop" id="mobile-backdrop"></div>
      <div class="mobile-drawer" id="mobile-drawer">
        <div class="mobile-drawer-handle"></div>
        <div class="mobile-drawer-content">
          <a href={`/${lang}/`} class="mobile-drawer-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            {lang === "zh" ? "首页" : "Home"}
          </a>
          <a href={`/${lang}/search/`} class="mobile-drawer-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
            {lang === "zh" ? "搜索" : "Search"}
          </a>
          <a href={`/${lang}/about/`} class="mobile-drawer-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 16v-4M12 8h.01"></path>
            </svg>
            {lang === "zh" ? "关于" : "About"}
          </a>
          <div class="mobile-drawer-divider"></div>
          <div class="mobile-drawer-lang">
            <span class="mobile-drawer-lang-label">{lang === "zh" ? "语言" : "Language"}</span>
            <div class="mobile-drawer-lang-btns">
              <a
                href={currentPath.replace(/^\/zh/, "/en")}
                class={`lang-btn ${lang === 'en' ? 'active' : ''}`}>EN</a>
              <a
                href={currentPath.replace(/^\/en/, "/zh")}
                class={`lang-btn ${lang === 'zh' ? 'active' : ''}`}>中文</a>
            </div>
          </div>
        </div>
      </div>

      <main>
        <slot />
      </main>

      <Footer lang={lang} />
    </div>
    <CookieConsent lang={lang} />
  </body>
</html>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid transparent;
    transition: box-shadow 0.2s ease;
  }

  .header.scrolled {
    /* box-shadow: 0 1px 8px rgba(0,0,0,0.06); */
    z-index: 199;
    border-bottom-color: #f0f0f0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 20px;
  }

  .header-link {
    text-decoration: none;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }

  .header-link:hover {
    opacity: 0.8;
  }

  .header-brand {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 22px;
    line-height: 1.25;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .header-subtitle {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: var(--text-muted);
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .header-icon-btn:hover {
    background: #f5f5f5;
    color: var(--text-primary);
  }

  .header-link-btn {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 16px;
    transition: background 0.2s ease, color 0.2s ease;
    letter-spacing: 0.04em;
  }

  .header-link-btn:hover {
    background: #f5f5f5;
    color: var(--text-primary);
  }

  .lang-switch {
    display: flex;
    background: #f5f5f5;
    padding: 3px;
    border-radius: 20px;
    gap: 2px;
    border: 1px solid #e8e8e8;
  }

  .lang-btn {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 5px 12px;
    border-radius: 16px;
    cursor: pointer;
    letter-spacing: 0.06em;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-block;
  }

  .lang-btn.active {
    background: var(--text-primary);
    color: #ffffff;
  }

  .lang-btn:hover:not(.active) {
    background: #e8e8e8;
  }

  .mobile-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: var(--text-primary);
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .mobile-menu-btn:active {
    background: #f0f0f0;
  }

  @media (max-width: 768px) {
    .header-inner {
      padding: 12px 16px;
    }

    .header-brand {
      font-size: 20px;
    }

    .header-subtitle {
      font-size: 10px;
    }

    .desktop-only {
      display: none !important;
    }

    .lang-switch {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }

  @media (min-width: 769px) {
    .desktop-only {
      display: inline-flex;
    }
  }

  .overlay-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    z-index: 200;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s;
  }

  .overlay-backdrop.visible {
    opacity: 1;
    visibility: visible;
  }

  .mobile-drawer {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    width: 100%;
    max-width: 1200px;
    background: #ffffff;
    border-radius: 24px 24px 0 0;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
    z-index: 210;
    padding: 16px 0 32px;
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1), visibility 0.35s;
    visibility: hidden;
    pointer-events: none;
  }

  .mobile-drawer.visible {
    transform: translateX(-50%) translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-drawer-handle {
    width: 32px;
    height: 4px;
    background: #e0e0e0;
    border-radius: 2px;
    margin: 0 auto 18px;
  }

  .mobile-drawer-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 20px;
  }

  .mobile-drawer-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 15px;
    color: var(--text-primary);
    text-decoration: none;
    padding: 14px 12px;
    border-radius: 12px;
    transition: background 0.15s ease;
    letter-spacing: 0.03em;
  }

  .mobile-drawer-item:active {
    background: #f5f5f5;
  }

  .mobile-drawer-item svg {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .mobile-drawer-divider {
    height: 1px;
    background: #f0f0f0;
    margin: 8px 12px;
  }

  .mobile-drawer-lang {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 12px;
  }

  .mobile-drawer-lang-label {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 15px;
    color: var(--text-primary);
    letter-spacing: 0.03em;
  }

  .mobile-drawer-lang-btns {
    display: flex;
    background: #f5f5f5;
    padding: 3px;
    border-radius: 20px;
    gap: 2px;
    border: 1px solid #e8e8e8;
  }

</style>

<script is:inline>
(function() {
  const header = document.getElementById("site-header");
  const menuBtn = document.getElementById("mobile-menu-btn");
  const drawer = document.getElementById("mobile-drawer");
  const backdrop = document.getElementById("mobile-backdrop");

  function closeDrawer() {
    if (drawer) drawer.classList.remove("visible");
    if (backdrop) backdrop.classList.remove("visible");
    document.body.classList.remove("scroll-locked");
  }

  function openDrawer() {
    if (drawer) drawer.classList.add("visible");
    if (backdrop) backdrop.classList.add("visible");
    document.body.classList.add("scroll-locked");
  }

  if (menuBtn) {
    menuBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (drawer && drawer.classList.contains("visible")) {
        closeDrawer();
      } else {
        openDrawer();
      }
    });
  }

  if (backdrop) {
    backdrop.addEventListener("click", closeDrawer);
  }

  let ticking = false;
  if (header) {
    window.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          header.classList.toggle("scrolled", window.scrollY > 10);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
})();
</script>
