---
import BaseLayout from "@layouts/BaseLayout.astro";
import ComicCard from "@components/ComicCard.astro";
import ComicDrawer from "@components/ComicDrawer.astro";
import { searchComics, HOT_ZH, HOT_EN } from "@lib/api";
import { t } from "@lib/i18n";
import type { Locale } from "@lib/i18n";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "zh" } },
  ];
}

const { lang } = Astro.params as { lang: string };

const VALID_LOCALES = ["en", "zh"];
if (!VALID_LOCALES.includes(lang)) {
  return Astro.redirect("/zh/", 302);
}

const typedLang = lang as Locale;
const q = Astro.url.searchParams.get("q") || "";
const rawPage = parseInt(Astro.url.searchParams.get("page") || "1", 10);
const searchPage = rawPage >= 1 ? rawPage : 1;
const PAGE_SIZE = 20;

let items: Awaited<ReturnType<typeof searchComics>>["items"] = [];
let total = 0;
let searchTotalPages = 1;
let error: string | null = null;

if (q) {
  try {
    const result = await searchComics({ keyword: q, sort: "default", page: searchPage, pageSize: PAGE_SIZE });
    items = result.items;
    total = result.total;
    searchTotalPages = Math.ceil(total / PAGE_SIZE) || 1;
  } catch (e) {
    error = e instanceof Error ? e.message : "Search failed";
  }
}

const hotWords = typedLang === "zh" ? HOT_ZH : HOT_EN;

const showSearchPagination = q && !error && items.length > 0 && searchTotalPages > 1;
const prevSearchUrl = `/${typedLang}/search/?q=${encodeURIComponent(q)}&page=${searchPage - 1}`;
const nextSearchUrl = `/${typedLang}/search/?q=${encodeURIComponent(q)}&page=${searchPage + 1}`;
---

<BaseLayout
  lang={typedLang}
  title={
    q
      ? `${typedLang === "zh" ? `搜索: "${q}"` : `Search: "${q}"`} — ${t("site.title", typedLang)}`
      : t("site.title", typedLang)
  }
>
  <div class="search-page">
    <div class="search-hero">
      <div class="inner-container">
        <div class="search-form-wrapper">
          <form class="search-form" action={`/${typedLang}/search/`} method="GET">
            <span class="search-form-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
              </svg>
            </span>
            <input
              class="search-form-input"
              type="text"
              name="q"
              value={q}
              placeholder={t("search.placeholder", typedLang)}
              autocomplete="off"
              autofocus={q.length === 0}
            />
            <button class="search-form-submit" type="submit">
              {typedLang === "zh" ? "搜索" : "Search"}
            </button>
          </form>
        </div>

        <div class="hot-searches">
          <span class="hot-label">{t("search.hot", typedLang)}</span>
          <div class="hot-tags">
            {hotWords.map((word) => (
              <a class="hot-tag" href={`/${typedLang}/search/?q=${encodeURIComponent(word)}`}>
                {word}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    
      {
        q && (
          <div class="search-header">
            <div class="inner-container">
            <h1 class="search-title">
              {typedLang === "zh" ? `搜索: "${q}"` : `Search: "${q}"`}
            </h1>
            <p class="search-count">
              {error
                ? (typedLang === "zh" ? "搜索出错了" : "Search failed")
                : typedLang === "zh"
                  ? `找到 ${total} 个结果`
                  : `${total} result${total !== 1 ? "s" : ""} found`}
            </p>
          </div> </div>
        )
      }
   
      {
        error ? (
          <p class="error-message">{error}</p>
        ) : items.length > 0 ? (
          <div class="waterfall-grid search-results" id="waterfall">
            {items.map((comic) => (
              <ComicCard comic={comic} lang={typedLang} />
            ))}
          </div>
        ) : q ? (
          <div class="no-results">
            <span class="no-results-emoji">🔍</span>
            <p class="no-results-text">{t("search.noResults", typedLang)}</p>
          </div>
        ) : (
          <div class="no-results no-query">
            <span class="no-results-emoji">✨</span>
            <p class="no-results-text">
              {typedLang === "zh" ? "输入关键词开始搜索" : "Enter a keyword to start searching"}
            </p>
          </div>
        )
      }
  </div>

  {
    showSearchPagination && (
      <div class="pagination" id="pagination-search">
        {
          searchPage > 1 ? (
            <a class="pagination-btn" href={prevSearchUrl}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"></path></svg>
              {typedLang === "zh" ? "上一页" : "Previous"}
            </a>
          ) : (
            <span class="pagination-btn disabled">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"></path></svg>
              {typedLang === "zh" ? "上一页" : "Previous"}
            </span>
          )
        }
        <span class="pagination-info">{typedLang === "zh" ? `第 ${searchPage} / ${searchTotalPages} 页` : `Page ${searchPage} / ${searchTotalPages}`}</span>
        {
          searchPage < searchTotalPages ? (
            <a class="pagination-btn" href={nextSearchUrl}>
              {typedLang === "zh" ? "下一页" : "Next"}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>
            </a>
          ) : (
            <span class="pagination-btn disabled">
              {typedLang === "zh" ? "下一页" : "Next"}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>
            </span>
          )
        }
      </div>
    )
  }

  <div class="overlay-backdrop" id="backdrop"></div>

  <ComicDrawer lang={typedLang} comic={items[0] || { id: 0, title: { zh: "", en: "" }, text: { zh: "", en: "" }, image: "", date: "", likes: 0, tags: { zh: [], en: [] } }} />
</BaseLayout>

<script type="application/json" id="search-data" set:html={JSON.stringify(items)}></script>

<script>
  import { likeComic } from "@lib/api";
  // @ts-ignore
  window.__likeComic = likeComic;
</script>

<script is:inline>
(function() {
  const state = {
    liked: new Set(),
    detailComic: null
  };

  const itemsData = JSON.parse(document.getElementById("search-data").textContent || "[]");
  const ITEMS = itemsData;

  const comicsById = new Map();
  for (const c of itemsData) comicsById.set(c.id, c);
  function getComicById(id) { return comicsById.get(id) || null; }

  function formatLikesLocal(n, lang) {
    if (lang === "zh" && n >= 10000) {
      return (n / 10000).toFixed(1) + "万";
    }
    return n.toLocaleString(lang === "zh" ? "zh-CN" : "en-US");
  }

  function getShareUrl(comic) {
    const base = window.location.origin + window.location.pathname;
    return base + "comic/" + comic.id;
  }

  function getShareTitle(comic, lang) {
    return lang === "zh" ? comic.title.zh : comic.title.en;
  }

  function getShareText(comic, lang) {
    return lang === "zh" ? comic.text.zh : comic.text.en;
  }

  async function handleShare(comic) {
    const lang = window.location.pathname.split("/")[1];
    const title = getShareTitle(comic, lang);
    const text = getShareText(comic, lang);
    const url = getShareUrl(comic);
    const shareText = title + " — " + text.replace(/\n/g, " ");

    if (navigator.share) {
      try {
        await navigator.share({ title, text: shareText, url });
        return;
      } catch (e) {
        if (e.name !== "AbortError") console.error("Share failed:", e);
      }
    }

    showShareModal(comic);
  }

  function buildShareModal(comic, lang) {
    const url = encodeURIComponent(getShareUrl(comic));
    const title = encodeURIComponent(getShareTitle(comic, lang));
    const text = encodeURIComponent(getShareText(comic, lang).replace(/\n/g, " "));
    const image = encodeURIComponent(comic.image);

    const platforms = [
      {
        name: "X",
        className: "share-platform-x",
        href: `https://twitter.com/intent/tweet?url=${url}&text=${title}%20%E2%80%94%20${text}`,
        svg: '<path d="M4 4h4.5l4.9 7 5.6-7H22l-6.6 8.4 6.6 9.6h-4.5l-5.3-7.7-6.1 7.7H2l7.2-9L4 4z"/>'
      },
      {
        name: "Facebook",
        className: "share-platform-fb",
        href: `https://www.facebook.com/sharer/sharer.php?u=${url}`,
        svg: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>'
      },
      {
        name: "WhatsApp",
        className: "share-platform-wa",
        href: `https://api.whatsapp.com/send?text=${text}%20${url}`,
        svg: '<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.83 11.83 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.9 11.9 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.82 11.82 0 0 0-3.48-8.413z"/>'
      },
      {
        name: "Pinterest",
        className: "share-platform-pin",
        href: `https://pinterest.com/pin/create/button/?url=${url}&media=${image}&description=${title}%20%E2%80%94%20${text}`,
        svg: '<path d="M12 0a12 12 0 0 0-4.73 23.1c-.06-.56-.01-1.22.12-1.83l.88-3.74s-.22-.44-.22-1.08c0-1.02.59-1.78 1.32-1.78.62 0 .92.47.92 1.03 0 .62-.4 1.56-.6 2.42-.17.72.36 1.3 1.07 1.3 1.28 0 2.27-1.35 2.27-3.3 0-1.73-1.24-2.94-3-2.94-2.05 0-3.25 1.54-3.25 3.13 0 .62.24 1.28.53 1.64.06.07.07.13.05.2l-.18.74c-.03.13-.1.16-.24.1-.9-.42-1.46-1.73-1.46-2.78 0-2.26 1.64-4.34 4.74-4.34 2.49 0 4.42 1.77 4.42 4.14 0 2.47-1.56 4.46-3.72 4.46-.73 0-1.41-.38-1.64-.82l-.45 1.7c-.16.62-.6 1.4-.9 1.88A12 12 0 1 0 12 0z"/>'
      },
      {
        name: "Copy Link",
        className: "share-platform-copy",
        href: "#",
        svg: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>'
      }
    ];

    const platformLinks = platforms.map(p => {
      if (p.className === "share-platform-copy") {
        return `<a class="share-platform ${p.className}" href="#" data-action="copy-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${p.svg}</svg>
          <span>${p.name}</span>
        </a>`;
      }
      return `<a class="share-platform ${p.className}" href="${p.href}" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor">${p.svg}</svg>
        <span>${p.name}</span>
      </a>`;
    }).join("");

    return `
      <div class="share-modal-backdrop"></div>
      <div class="share-modal">
        <div class="share-modal-handle"></div>
        <div class="share-modal-title">${lang === "zh" ? "分享到" : "Share to"}</div>
        <div class="share-platforms">${platformLinks}</div>
        <button class="share-modal-close">${lang === "zh" ? "取消" : "Cancel"}</button>
      </div>
    `;
  }

  function showShareModal(comic) {
    const existing = document.querySelector(".share-modal-overlay");
    if (existing) existing.remove();

    const lang = window.location.pathname.split("/")[1];
    const overlay = document.createElement("div");
    overlay.className = "share-modal-overlay";
    overlay.innerHTML = buildShareModal(comic, lang);
    document.body.appendChild(overlay);

    requestAnimationFrame(() => overlay.classList.add("visible"));

    overlay.querySelector(".share-modal-backdrop").addEventListener("click", closeShareModal);
    overlay.querySelector(".share-modal-close").addEventListener("click", closeShareModal);

    const copyBtn = overlay.querySelector('[data-action="copy-link"]');
    if (copyBtn) {
      copyBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        const url = getShareUrl(comic);
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          const input = document.createElement("input");
          input.value = url;
          document.body.appendChild(input);
          input.select();
          document.execCommand("copy");
          document.body.removeChild(input);
        }
        copyBtn.querySelector("span").textContent = lang === "zh" ? "已复制" : "Copied";
        setTimeout(() => {
          copyBtn.querySelector("span").textContent = "Copy Link";
        }, 1500);
      });
    }
  }

  function closeShareModal() {
    const overlay = document.querySelector(".share-modal-overlay");
    if (!overlay) return;
    overlay.classList.remove("visible");
    setTimeout(() => { if (overlay.parentNode) overlay.remove(); }, 300);
  }

  function updateLikeBtn(btn, comicId) {
    const liked = state.liked.has(comicId);
    const comic = getComicById(comicId);
    const lang = window.location.pathname.split("/")[1];
    if (!comic) return;

    btn.classList.toggle("liked", liked);
    btn.innerHTML = `
      <svg width="12" height="12" viewBox="0 0 24 24" fill="${liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <span>${formatLikesLocal(comic.likes + (liked ? 1 : 0), lang)}</span>
    `;
  }

  function triggerLikeAnimation(container) {
    if (!container) return;
    if (getComputedStyle(container).position === 'static') container.style.position = 'relative';

    const wrapper = document.createElement('div');
    wrapper.className = 'like-anim-wrapper';

    wrapper.innerHTML = `
      <svg class="like-anim-heart" viewBox="0 0 24 24" fill="var(--heart-active)">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    `;

    for (let i = 0; i < 8; i++) {
      const p = document.createElement('div');
      p.className = 'like-anim-particle';
      p.style.setProperty('--angle', (360 / 8) * i + 'deg');
      p.style.setProperty('--dist', '80px');
      wrapper.appendChild(p);
    }
    for (let i = 0; i < 8; i++) {
      const p = document.createElement('div');
      p.className = 'like-anim-particle';
      p.style.setProperty('--angle', ((360 / 8) * i + 22.5) + 'deg');
      p.style.setProperty('--dist', '110px');
      p.style.animationDelay = '0.08s';
      wrapper.appendChild(p);
    }

    container.appendChild(wrapper);
    setTimeout(() => { if (wrapper.parentNode) wrapper.remove(); }, 850);
  }

  function openDetail(comic) {
    state.detailComic = comic;
    renderDetailSheet();
    document.body.classList.add('scroll-locked');
  }

  function closeDetail() {
    state.detailComic = null;
    renderDetailSheet();
    document.body.classList.remove('scroll-locked');
  }

  function renderDetailSheet() {
    const drawer = document.getElementById("comic-drawer");
    const lang = window.location.pathname.split("/")[1];
    const backdrop = document.getElementById("backdrop");

    if (!drawer) return;

    if (!state.detailComic) {
      drawer.classList.remove("visible");
      if (backdrop) backdrop.classList.remove("visible");
      return;
    }

    const comic = state.detailComic;
    const title = lang === "zh" ? comic.title.zh : comic.title.en;
    const text = lang === "zh" ? comic.text.zh : comic.text.en;
    const liked = state.liked.has(comic.id);

    let display = drawer.querySelector(".detail-display");
    if (!display) {
      const content = `
        <div class="detail-header">
          <div class="detail-header-title"></div>
          <button class="detail-close" id="detail-close">\u00d7</button>
        </div>
        <div class="detail-content">
          <div class="card-stack">
            <div class="card-stack-shadow-1"></div>
            <div class="card-stack-shadow-2"></div>
            <div class="detail-display">
              <img class="detail-image" />
              <p class="detail-text"></p>
            </div>
          </div>
          <div class="detail-meta">
            <div>
              <div class="detail-title"></div>
              <div class="detail-date"></div>
            </div>
            <div class="detail-actions">
              <button class="like-btn" data-action="like" data-id=""></button>
              <button class="share-btn detail-share-btn" data-action="share" data-id="">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="18" cy="5" r="3"></circle>
                  <circle cx="6" cy="12" r="3"></circle>
                  <circle cx="18" cy="19" r="3"></circle>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                  <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                </svg>
              </button>
            </div>
          </div>
          <div class="detail-tags"></div>
          <div class="detail-author">
            <div class="detail-author-avatar">\ud83c\udfa8</div>
            <div class="detail-author-info">
              <h4></h4>
              <p></p>
            </div>
          </div>
        </div>
      `;
      drawer.innerHTML = content;
    }

    drawer.querySelector(".detail-header-title").textContent = lang === "zh" ? "漫画详情" : "Comic Details";
    drawer.querySelector(".detail-image").src = comic.image;
    drawer.querySelector(".detail-image").alt = title;
    drawer.querySelector(".detail-text").innerHTML = text.replace(/\n/g, "<br/>");
    drawer.querySelector(".detail-title").textContent = title;
    drawer.querySelector(".detail-date").textContent = comic.date;
    const likeBtn = drawer.querySelector(".like-btn");
    likeBtn.className = `like-btn ${liked ? "liked" : ""}`;
    likeBtn.dataset.id = comic.id;
    likeBtn.innerHTML = `
      <svg width="18" height="18" viewBox="0 0 24 24" fill="${liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <span>${formatLikesLocal(comic.likes + (liked ? 1 : 0), lang)}</span>
    `;
    const shareBtn = drawer.querySelector(".share-btn");
    if (shareBtn) shareBtn.dataset.id = comic.id;

    drawer.querySelector(".detail-tags").innerHTML = (comic.tags[lang] || []).map(tag =>
      `<span class="detail-tag">${tag}</span>`
    ).join("");
    drawer.querySelector(".detail-author-info h4").textContent = lang === "zh" ? "小林" : "Xiaolin";
    drawer.querySelector(".detail-author-info p").textContent = lang === "zh" ? "用画笔记录生活的温暖瞬间" : "Capturing life's warm moments";

    const closeBtn = drawer.querySelector("#detail-close");
    if (closeBtn) {
      closeBtn.onclick = closeDetail;
    }

    const detailLikeBtn = drawer.querySelector(".like-btn");
    if (detailLikeBtn) {
      detailLikeBtn.onclick = (e) => {
        e.stopPropagation();
        const id = parseInt(detailLikeBtn.dataset.id || "0");
        const wasLiked = state.liked.has(id);
        if (wasLiked) {
          state.liked.delete(id);
        } else {
          state.liked.add(id);
          window.__likeComic(id);
        }

        const comic = getComicById(id);
        const lang = window.location.pathname.split("/")[1];
        const liked = state.liked.has(id);
        detailLikeBtn.className = `like-btn ${liked ? "liked" : ""}`;
        detailLikeBtn.innerHTML = `
          <svg width="18" height="18" viewBox="0 0 24 24" fill="${liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <span>${formatLikesLocal(comic.likes + (liked ? 1 : 0), lang)}</span>
        `;

        document.querySelectorAll(`.like-btn[data-id="${id}"]`).forEach(btn => {
          if (btn !== detailLikeBtn) {
            updateLikeBtn(btn, id);
          }
        });

        if (!wasLiked) {
          const display = drawer.querySelector('.detail-display');
          triggerLikeAnimation(display);
        }
      };
    }

    const detailShareBtn = drawer.querySelector(".share-btn");
    if (detailShareBtn) {
      detailShareBtn.onclick = (e) => {
        e.stopPropagation();
        const id = parseInt(detailShareBtn.dataset.id || "0");
        const comic = getComicById(id);
        if (comic) handleShare(comic);
      };
    }

    drawer.classList.add("visible");
    if (backdrop) {
      backdrop.classList.add("visible");
      backdrop.onclick = () => {
        if (state.detailComic) {
          closeDetail();
        }
      };
    }
  }

  function setupClicks() {
    const waterfall = document.getElementById("waterfall");
    if (!waterfall) return;

    waterfall.addEventListener("click", (e) => {
      const target = e.target;
      const likeBtn = target.closest(".like-btn");

      if (likeBtn) {
        const id = parseInt(likeBtn.dataset.id || "0");
        const wasLiked = state.liked.has(id);
        if (wasLiked) {
          state.liked.delete(id);
        } else {
          state.liked.add(id);
          window.__likeComic(id);
        }
        updateLikeBtn(likeBtn, id);

        if (!wasLiked) {
          const card = likeBtn.closest('.waterfall-card');
          triggerLikeAnimation(card);
        }
        return;
      }

      const shareBtn = target.closest(".share-btn");
      if (shareBtn) {
        e.stopPropagation();
        const id = parseInt(shareBtn.dataset.id || "0");
        const comic = getComicById(id);
        if (comic) handleShare(comic);
        return;
      }

      const card = target.closest(".waterfall-card");
      if (card) {
        const id = parseInt(card.dataset.comicId || "0");
        const comic = getComicById(id);
        if (comic) openDetail(comic);
      }
    });
  }

  setupClicks();
})();
</script>

