  function showShareModal(comic) {
    const existing = document.querySelector(".share-modal-overlay");
    if (existing) existing.remove();

    const lang = window.location.pathname.split("/")[1];
    const overlay = document.createElement("div");
    overlay.className = "share-modal-overlay";
    overlay.innerHTML = buildShareModal(comic, lang);
    document.body.appendChild(overlay);

    requestAnimationFrame(() => overlay.classList.add("visible"));

    overlay.querySelector(".share-modal-backdrop").addEventListener("click", closeShareModal);
    overlay.querySelector(".share-modal-close").addEventListener("click", closeShareModal);

    const copyBtn = overlay.querySelector('[data-action="copy-link"]');
    if (copyBtn) {
      copyBtn.addEventListener("click", async (e) => {
        e.preventDefault();
        const url = getShareUrl(comic);
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          const input = document.createElement("input");
          input.value = url;
          document.body.appendChild(input);
          input.select();
          document.execCommand("copy");
          document.body.removeChild(input);
        }
        copyBtn.querySelector("span").textContent = lang === "zh" ? "已复制" : "Copied";
        setTimeout(() => {
          copyBtn.querySelector("span").textContent = "Copy Link";
        }, 1500);
      });
    }
  }

  function closeShareModal() {
    const overlay = document.querySelector(".share-modal-overlay");
    if (!overlay) return;
    overlay.classList.remove("visible");
    setTimeout(() => { if (overlay.parentNode) overlay.remove(); }, 300);
  }

  async function generatePoster(comic, lang) {
    const brand = lang === "zh" ? "小林漫画" : "Xiaolin Comics";

    const drawer = document.getElementById("comic-drawer");
    const originalCard = drawer.querySelector(".card-stack");
    if (!originalCard) throw new Error("Card-stack not found");

    const cardClone = originalCard.cloneNode(true);

    const container = document.createElement("div");
    container.style.cssText = "display:inline-block;background:#ffffff;padding:32px 28px 18px;";

    cardClone.style.marginBottom = "0";
    container.appendChild(cardClone);

    const brandEl = document.createElement("div");
    brandEl.style.cssText = "text-align:center;font-family:'Noto Sans SC',sans-serif;font-size:12px;color:#bbbbbb;letter-spacing:0.08em;padding:16px 0 8px;";
    brandEl.textContent = brand;
    container.appendChild(brandEl);

    container.style.position = "fixed";
    container.style.left = "-9999px";
    container.style.top = "0";
    container.style.zIndex = "-1";
    document.body.appendChild(container);

    const imgs = container.querySelectorAll("img");
    Array.from(imgs).forEach(function (img) {
      var src = img.getAttribute("src");
      if (src && src.startsWith("http") && !src.startsWith(location.origin)) {
        img.setAttribute("src", "/api/proxy-image?url=" + encodeURIComponent(src));
      }
    });

    await Promise.all(Array.from(imgs).map(function (img) {
      if (img.complete && img.naturalWidth > 0) return;
      return new Promise(function (resolve) {
        img.onload = resolve;
        img.onerror = resolve;
      });
    }));

    try {
      const scale = 3;
      const canvas = await html2canvas(container, {
        scale: scale,
        useCORS: true,
        backgroundColor: "#ffffff",
        logging: false,
        width: container.scrollWidth,
        height: container.scrollHeight,
      });
      return canvas.toDataURL("image/png");
    } finally {
      document.body.removeChild(container);
    }
  }

  async function showPosterModal(comic, lang) {
    const existing = document.querySelector(".poster-modal-overlay");
    if (existing) existing.remove();

    const overlay = document.createElement("div");
    overlay.className = "poster-modal-overlay";

    const loadingText = lang === "zh" ? "生成海报中..." : "Generating poster...";
    overlay.innerHTML =
      '<div class="poster-modal-backdrop"></div>' +
      '<div class="poster-modal">' +
        '<div class="poster-modal-loading">' + loadingText + '</div>' +
      '</div>';

    document.body.appendChild(overlay);
    requestAnimationFrame(() => overlay.classList.add("visible"));

    try {
      const dataUrl = await generatePoster(comic, lang);
      const saveText = lang === "zh" ? "保存图片" : "Save Image";
      const closeText = lang === "zh" ? "关闭" : "Close";
      const title = lang === "zh" ? comic.title.zh : comic.title.en;

      overlay.innerHTML =
        '<div class="poster-modal-backdrop"></div>' +
        '<div class="poster-modal">' +
          '<div class="poster-modal-handle"></div>' +
          '<div class="poster-modal-title">' + title + '</div>' +
          '<div class="poster-modal-preview">' +
            '<img class="poster-modal-image" src="' + dataUrl + '" alt="' + title + '" />' +
          '</div>' +
          '<div class="poster-modal-actions">' +
            '<button class="poster-save-btn">' + saveText + '</button>' +
            '<button class="poster-close-btn">' + closeText + '</button>' +
          '</div>' +
        '</div>';

      overlay.querySelector(".poster-modal-backdrop").addEventListener("click", closePosterModal);
      overlay.querySelector(".poster-close-btn").addEventListener("click", closePosterModal);

      const saveBtn = overlay.querySelector(".poster-save-btn");
      saveBtn.addEventListener("click", () => {
        const a = document.createElement("a");
        a.href = dataUrl;
        a.download = title.replace(/[^a-zA-Z0-9\u4e00-\u9fa5]/g, "_") + ".png";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);

        const savedText = lang === "zh" ? "已保存" : "Saved";
        saveBtn.textContent = savedText;
        setTimeout(() => { saveBtn.textContent = saveText; }, 2000);
      });
    } catch (e) {
      overlay.innerHTML =
        '<div class="poster-modal-backdrop"></div>' +
        '<div class="poster-modal">' +
          '<div class="poster-modal-handle"></div>' +
          '<div class="poster-modal-error">' + (lang === "zh" ? "海报生成失败" : "Poster generation failed") + '</div>' +
          '<button class="poster-close-btn">' + (lang === "zh" ? "关闭" : "Close") + '</button>' +
        '</div>';
      overlay.querySelector(".poster-modal-backdrop").addEventListener("click", closePosterModal);
      overlay.querySelector(".poster-close-btn").addEventListener("click", closePosterModal);
    }
  }

  function closePosterModal() {
    const overlay = document.querySelector(".poster-modal-overlay");
    if (!overlay) return;
    overlay.classList.remove("visible");
    setTimeout(() => { if (overlay.parentNode) overlay.remove(); }, 300);
  }

  function getFiltered() {
    return [...COMICS];
  }

  function renderAll() {
    renderTags();
    renderWaterfall();
    renderDetailSheet();
    renderTagDrawer();
  }

  function renderTags() {
    const tagFilter = document.getElementById("tag-filter");
    const tagDrawerGrid = document.getElementById("tag-drawer-grid");
    const moreBtn = document.getElementById("more-btn");

    [tagFilter, tagDrawerGrid].forEach(container => {
      if (!container) return;
      const buttons = container.querySelectorAll(".tag-btn");
      buttons.forEach(btn => {
        btn.classList.toggle("active", btn.dataset.tag === state.activeTag);
      });
    });

    if (moreBtn) {
      const tagInDrawer = LABELS.slice(VISIBLE_LABEL_COUNT).includes(state.activeTag);
      moreBtn.classList.toggle("active", tagInDrawer);
    }
  }

  function renderWaterfall() {
    const filtered = getFiltered();
    const waterfall = document.getElementById("waterfall");
    const emptyState = document.getElementById("empty-state");
    const worksCount = document.getElementById("works-count");
    const loadSentinel = document.getElementById("load-sentinel");
    const lang = window.location.pathname.split("/")[1];

    if (!waterfall || !emptyState || !worksCount) return;

    const filterCount = state.isTagMode ? state.tagTotal : filtered.length;
    worksCount.textContent = lang === "zh" ? `共 ${filterCount} 幅作品` : `${filterCount} works`;

    if (filtered.length === 0) {
      emptyState.classList.add("visible");
      waterfall.style.display = "none";
      if (loadSentinel) loadSentinel.classList.remove("visible");
      return;
    }

    emptyState.classList.remove("visible");
    waterfall.style.display = "block";

    waterfall.innerHTML = "";
    filtered.forEach(comic => {
      const card = document.createElement("div");
      card.className = "waterfall-card";
      card.dataset.comicId = comic.id;

      const text = lang === "zh" ? comic.text.zh : comic.text.en;
      const title = lang === "zh" ? comic.title.zh : comic.title.en;
      const liked = state.liked.has(comic.id);

      card.innerHTML = `
        <img class="waterfall-image" src="${comic.image}" alt="${title}" draggable="false" loading="lazy" />
        <p class="waterfall-text">${text.replace(/\n/g, "<br/>")}</p>
        <div class="waterfall-tags-row">
          ${(comic.tags[lang] || []).slice(0, 1).map(tag => `<span class="waterfall-tag">${tag}</span>`).join("")}
        </div>
        <div class="waterfall-meta">
          <button class="like-btn ${liked ? "liked" : ""}" data-action="like" data-id="${comic.id}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="${liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
            <span>${formatLikesLocal(comic.likes + (liked ? 1 : 0), lang)}</span>
          </button>
          <button class="share-btn" data-action="share" data-id="${comic.id}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="18" cy="5" r="3"></circle>
              <circle cx="6" cy="12" r="3"></circle>
              <circle cx="18" cy="19" r="3"></circle>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
            </svg>
          </button>
        </div>
      `;
      waterfall.appendChild(card);
    });
  }

  function updateLikeBtn(btn, comicId) {
    const liked = state.liked.has(comicId);
    const comic = getComicById(comicId);
    const lang = window.location.pathname.split("/")[1];
    if (!comic) return;

    btn.classList.toggle("liked", liked);
    btn.innerHTML = `
      <svg width="12" height="12" viewBox="0 0 24 24" fill="${liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <span>${formatLikesLocal(comic.likes + (liked ? 1 : 0), lang)}</span>
    `;
  }

  function triggerLikeAnimation(container) {
    if (!container) return;
    if (getComputedStyle(container).position === 'static') container.style.position = 'relative';

    const wrapper = document.createElement('div');
    wrapper.className = 'like-anim-wrapper';

    wrapper.innerHTML = `
      <svg class="like-anim-heart" viewBox="0 0 24 24" fill="var(--heart-active)">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    `;

    for (let i = 0; i < 8; i++) {
      const p = document.createElement('div');
      p.className = 'like-anim-particle';
      p.style.setProperty('--angle', (360 / 8) * i + 'deg');
      p.style.setProperty('--dist', '80px');
      wrapper.appendChild(p);
    }
    for (let i = 0; i < 8; i++) {
      const p = document.createElement('div');
      p.className = 'like-anim-particle';
      p.style.setProperty('--angle', ((360 / 8) * i + 22.5) + 'deg');
      p.style.setProperty('--dist', '110px');
      p.style.animationDelay = '0.08s';
      wrapper.appendChild(p);
    }

    container.appendChild(wrapper);
    setTimeout(() => { if (wrapper.parentNode) wrapper.remove(); }, 850);
  }

  function renderDetailSheet() {
    const drawer = document.getElementById("comic-drawer");
    const lang = window.location.pathname.split("/")[1];

    if (!drawer) return;

    if (!state.detailComic) {
      drawer.classList.remove("visible");
      return;
    }

    const comic = state.detailComic;
    const title = lang === "zh" ? comic.title.zh : comic.title.en;
    const text = lang === "zh" ? comic.text.zh : comic.text.en;
    const liked = state.liked.has(comic.id);

    let display = drawer.querySelector(".detail-display");
    if (!display) {
      const content = `
        <div class="detail-header">
          <div class="detail-header-title"></div>
          <button class="detail-close" id="detail-close">\u00d7</button>
        </div>
        <div class="detail-content">
          <div class="card-stack">
            <div class="card-stack-shadow-1"></div>
            <div class="card-stack-shadow-2"></div>
            <div class="detail-display">
              <img class="detail-image" />
              <p class="detail-text"></p>
            </div>
          </div>
          <div class="detail-meta">
            <div>
              <div class="detail-title"></div>
              <div class="detail-date"></div>
