---
import type { Comic, LabelItem } from "@lib/api";
import { t, formatLikes } from "@lib/i18n";
import type { Locale } from "@lib/i18n";
import Carousel from "./Carousel.astro";
import ComicCard from "./ComicCard.astro";
import ComicDrawer from "./ComicDrawer.astro";

export interface Props {
  lang: Locale;
  comics: Comic[];
  featured: Comic[];
  labels: LabelItem[];
  currentPage: number;
  totalPages: number;
  total: number;
}

const {
  lang,
  comics,
  featured,
  labels,
  currentPage,
  totalPages,
  total,
} = Astro.props;

const prevPageUrl = currentPage <= 2 ? `/${lang}/` : `/${lang}/page/${currentPage - 1}`;
const nextPageUrl = `/${lang}/page/${currentPage + 1}`;
const showPagination = totalPages > 1;
---

<Carousel comics={featured} lang={lang} />

<div class="inner-container" id="page-section">
  <div class="tag-filter" id="tag-filter">
    <button class="tag-btn active" data-tag="">{lang === "zh" ? "全部" : "All"}</button>
    {labels.slice(0, 4).map((label) => (
      <button class="tag-btn" data-tag={label.name}>{label.name}</button>
    ))}
    <button class="more-btn" id="more-btn" class:list={[{ hidden: labels.length <= 4 }]}>{t("tags.more", lang)}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"></path></svg>
    </button>
  </div>

  <div class="works-count" id="works-count">{lang === "zh" ? `共 ${total} 幅作品` : `${total} works`}</div>
</div>

{
  showPagination && (
    <div class="pagination" id="pagination-top">
      {
        currentPage > 1 ? (
          <a class="pagination-btn" href={prevPageUrl+"#page-section"}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"></path></svg>
            {lang === "zh" ? "上一页" : "Previous"}
          </a>
        ) : (
          <span class="pagination-btn disabled">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"></path></svg>
            {lang === "zh" ? "上一页" : "Previous"}
          </span>
        )
      }
      <span class="pagination-info">{lang === "zh" ? `第 ${currentPage} / ${totalPages} 页` : `Page ${currentPage} / ${totalPages}`}</span>
      {
        currentPage < totalPages ? (
          <a class="pagination-btn" href={nextPageUrl+"#page-section"}>
            {lang === "zh" ? "下一页" : "Next"}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>
          </a>
        ) : (
          <span class="pagination-btn disabled">
            {lang === "zh" ? "下一页" : "Next"}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>
          </span>
        )
      }
    </div>
  )
}

<section class="waterfall-grid" id="waterfall">
  {comics.map((comic) => (
    <ComicCard comic={comic} lang={lang} />
  ))}
</section>

{
  showPagination && (
    <div class="pagination" id="pagination-bottom">
      {
        currentPage > 1 ? (
          <a class="pagination-btn" href={prevPageUrl+"#page-section"}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"></path></svg>
            {lang === "zh" ? "上一页" : "Previous"}
          </a>
        ) : (
          <span class="pagination-btn disabled">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"></path></svg>
            {lang === "zh" ? "上一页" : "Previous"}
          </span>
        )
      }
      <span class="pagination-info">{lang === "zh" ? `第 ${currentPage} / ${totalPages} 页` : `Page ${currentPage} / ${totalPages}`}</span>
      {
        currentPage < totalPages ? (
          <a class="pagination-btn" href={nextPageUrl+"#page-section"}>
            {lang === "zh" ? "下一页" : "Next"}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>
          </a>
        ) : (
          <span class="pagination-btn disabled">
            {lang === "zh" ? "下一页" : "Next"}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>
          </span>
        )
      }
    </div>
  )
}

<div class="empty-state" id="empty-state">
  <span class="empty-emoji">🔍</span>
  <span class="empty-text">{t("search.noResults", lang)}</span>
</div>

<div class="load-sentinel" id="load-sentinel">
  <div class="load-spinner"></div>
  <span class="load-text">{lang === "zh" ? "加载中…" : "Loading…"}</span>
</div>

<div class="overlay-backdrop" id="backdrop"></div>

<div class="tag-drawer" id="tag-drawer">
  <div class="tag-drawer-handle"></div>
  <div class="tag-drawer-title">{t("tags.allTags", lang)}</div>
  <div class="tag-drawer-grid" id="tag-drawer-grid">
    <button class="tag-btn active" data-tag="">{lang === "zh" ? "全部" : "All"}</button>
    {labels.map((label) => (
      <button class="tag-btn" data-tag={label.name}>{label.name}</button>
    ))}
  </div>
</div>

<ComicDrawer lang={lang} comic={comics[0]} />

<style>
  .tag-filter {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    padding: 0 20px;
    flex-wrap: wrap;
  }

  .tag-btn, .more-btn {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 11px;
    letter-spacing: 0.04em;
    padding: 7px 14px;
    border-radius: 20px;
    border: 1px solid #e8e8e8;
    background: #fafafa;
    color: var(--text-secondary);
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .tag-btn.active {
    background: var(--text-primary);
    color: #ffffff;
    border-color: var(--text-primary);
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }

  .more-btn {
    border-color: #ccc;
    background: transparent;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .more-btn:active {
    background: #f5f5f5;
  }

  .more-btn.hidden {
    display: none;
  }

  .more-btn svg {
    width: 10px;
    height: 10px;
  }

  .works-count {
    padding: 20px 20px 12px;
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.08em;
  }

  .empty-state {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 48px 20px;
    color: var(--text-faint);
  }

  .empty-state.visible {
    display: flex;
  }

  .empty-state .empty-emoji {
    font-size: 42px;
  }

  .empty-state .empty-text {
    font-size: 13px;
    letter-spacing: 0.04em;
  }

  .overlay-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    z-index: 200;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s;
  }

  .overlay-backdrop.visible {
    opacity: 1;
    visibility: visible;
  }

  .tag-drawer {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    width: 100%;
    max-width: 1200px;
    max-height: 60vh;
    background: #ffffff;
    border-radius: 24px 24px 0 0;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
    z-index: 210;
    padding: 16px 20px 32px;
    display: flex;
    flex-direction: column;
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1), visibility 0.35s;
    visibility: hidden;
    pointer-events: none;
  }

  .tag-drawer.visible {
    transform: translateX(-50%) translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  .tag-drawer-handle {
    width: 32px;
    height: 4px;
    background: #e0e0e0;
    border-radius: 2px;
    margin: 0 auto 18px;
    flex-shrink: 0;
  }

  .tag-drawer-title {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .tag-drawer-grid {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: 10px;
    overflow-y: auto;
    flex: 1;
    -webkit-overflow-scrolling: touch;
  }

  .load-sentinel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 24px 0 48px;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .load-sentinel.visible {
    opacity: 1;
  }

  .load-spinner {
    width: 28px;
    height: 28px;
    border: 2.5px solid #e8e8e8;
    border-top-color: #333;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .load-text {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 4px 6px;
    border-radius: 8px;
    transition: color 0.2s ease, transform 0.15s ease;
  }

  .share-btn:active {
    transform: scale(0.9);
    color: var(--text-secondary);
  }

  .detail-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .detail-share-btn {
    padding: 6px 10px;
    border-radius: 10px;
  }

  .share-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .share-modal-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .share-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  .share-modal {
    position: relative;
    width: 100%;
    max-width: 480px;
    background: #ffffff;
    border-radius: 24px 24px 0 0;
    padding: 16px 24px 32px;
    z-index: 1;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .share-modal-overlay.visible .share-modal {
    transform: translateY(0);
  }

  .share-modal-handle {
    width: 32px;
    height: 4px;
    background: #e0e0e0;
    border-radius: 2px;
    margin-bottom: 20px;
  }

  .share-modal-title {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 24px;
    letter-spacing: 0.03em;
  }

  .share-platforms {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .share-platform {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 64px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.15s ease;
  }

  .share-platform:active {
    transform: scale(0.9);
  }

  .share-platform svg {
    width: 40px;
    height: 40px;
    padding: 10px;
    border-radius: 50%;
  }

  .share-platform-x svg {
    background: #000;
    color: #fff;
  }

  .share-platform-fb svg {
    background: #1877F2;
    color: #fff;
  }

  .share-platform-wa svg {
    background: #25D366;
    color: #fff;
  }

  .share-platform-pin svg {
    background: #E60023;
    color: #fff;
  }

  .share-platform-copy svg {
    background: #f0f0f0;
    color: #333;
  }

  .share-platform span {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 11px;
    color: var(--text-secondary);
    letter-spacing: 0.04em;
    text-align: center;
  }

  .share-modal-close {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 13px;
    color: var(--text-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 24px;
    letter-spacing: 0.04em;
  }

  :global(.pagination) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 24px 20px 40px;
  }

  :global(.pagination-btn) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 13px;
    color: var(--text-primary);
    text-decoration: none;
    padding: 8px 16px;
    border-radius: 20px;
    border: 1px solid #e0e0e0;
    background: #ffffff;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.02em;
  }

  :global(.pagination-btn:active) {
    transform: scale(0.96);
  }

  :global(.pagination-btn:hover) {
    border-color: #333;
    background: #fafafa;
  }

  :global(.pagination-btn.disabled) {
    color: #ccc;
    border-color: #eee;
    background: #fafafa;
    cursor: not-allowed;
    pointer-events: none;
  }

  :global(.pagination-btn svg) {
    width: 14px;
    height: 14px;
  }

  :global(.pagination-info) {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  :global(.poster-modal-overlay) {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  :global(.poster-modal-overlay.visible) {
    opacity: 1;
    pointer-events: auto;
  }

  :global(.poster-modal-backdrop) {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  :global(.poster-modal) {
    position: relative;
    width: 100%;
    max-width: 420px;
    background: #ffffff;
    border-radius: 24px 24px 0 0;
    padding: 16px 20px 32px;
    z-index: 1;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    max-height: 90vh;
  }

  :global(.poster-modal-overlay.visible .poster-modal) {
    transform: translateY(0);
  }

  :global(.poster-modal-handle) {
    width: 32px;
    height: 4px;
    background: #e0e0e0;
    border-radius: 2px;
    margin-bottom: 14px;
    flex-shrink: 0;
  }

  :global(.poster-modal-title) {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  :global(.poster-modal-loading) {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 14px;
    color: var(--text-muted);
    padding: 60px 0;
    letter-spacing: 0.04em;
  }

  :global(.poster-modal-error) {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 14px;
    color: #e74c3c;
    padding: 40px 0 20px;
    letter-spacing: 0.04em;
  }

  :global(.poster-modal-preview) {
    width: 100%;
    display: flex;
    justify-content: center;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
  }

  :global(.poster-modal-image) {
    width: 100%;
    max-width: 300px;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    display: block;
  }

  :global(.poster-modal-actions) {
    display: flex;
    gap: 10px;
    width: 100%;
    margin-top: 18px;
    flex-shrink: 0;
  }

  :global(.poster-save-btn) {
    flex: 1;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #ffffff;
    background: var(--text-primary);
    border: none;
    border-radius: 12px;
    padding: 13px;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: opacity 0.2s ease, transform 0.15s ease;
  }

  :global(.poster-save-btn:active) {
    transform: scale(0.97);
    opacity: 0.85;
  }

  :global(.poster-close-btn) {
    flex: 1;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 14px;
    color: var(--text-secondary);
    background: #f5f5f5;
    border: none;
    border-radius: 12px;
    padding: 13px;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  :global(.poster-close-btn:active) {
    transform: scale(0.97);
    background: #eaeaea;
  }
</style>

<script type="application/json" id="api-config" set:html={JSON.stringify({
  apiBase: import.meta.env.PUBLIC_API_BASE || ""
})}></script>

<script type="application/json" id="comics-data" set:html={JSON.stringify(comics)}></script>

<script type="application/json" id="featured-data" set:html={JSON.stringify(featured)}></script>

<script type="application/json" id="labels-data" set:html={JSON.stringify(labels)}></script>

<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>

<script>
  import { likeComic, getComicsByTag } from "@lib/api";
  // @ts-ignore
  window.__likeComic = likeComic;
  // @ts-ignore
  window.__getComicsByTag = getComicsByTag;
</script>

<script is:inline>
(function() {
  const state = {
    activeTag: "",
    isTagMode: false,
    tagTotal: 0,
    tagPage: 1,
    tagTotalPages: 1,
    liked: new Set(),
    detailComic: null,
    tagDrawerOpen: false
  };

  const apiConfig = JSON.parse(document.getElementById("api-config").textContent || "{}");

  const comicsData = JSON.parse(document.getElementById("comics-data").textContent || "[]");
  const featuredData = JSON.parse(document.getElementById("featured-data").textContent || "[]");
  const COMICS = comicsData;
  const SSR_COMICS = [...comicsData];
  const SSR_PAGINATION = [];
  document.querySelectorAll(".pagination").forEach(el => {
    SSR_PAGINATION.push(el.innerHTML);
  });

  const comicsById = new Map();
  for (const c of comicsData) comicsById.set(c.id, c);
  for (const c of featuredData) if (!comicsById.has(c.id)) comicsById.set(c.id, c);
  function getComicById(id) { return comicsById.get(id) || null; }
  function rebuildComicsById(comics) {
    comicsById.clear();
    for (const c of comics) comicsById.set(c.id, c);
    for (const c of featuredData) if (!comicsById.has(c.id)) comicsById.set(c.id, c);
  }

  const labelsData = JSON.parse(document.getElementById("labels-data").textContent || "[]");
  const LABELS = labelsData.map(l => l.name);
  const VISIBLE_LABEL_COUNT = 4;

  function formatLikesLocal(n, lang) {
    if (lang === "zh" && n >= 10000) {
      return (n / 10000).toFixed(1) + "万";
    }
    return n.toLocaleString(lang === "zh" ? "zh-CN" : "en-US");
  }

  function getShareUrl(comic) {
    const base = window.location.origin + window.location.pathname;
    return base + "comic/" + comic.id;
  }

  function getShareTitle(comic, lang) {
    return lang === "zh" ? comic.title.zh : comic.title.en;
  }

  function getShareText(comic, lang) {
    return lang === "zh" ? comic.text.zh : comic.text.en;
  }

  async function handleShare(comic) {
    const lang = window.location.pathname.split("/")[1];
    const title = getShareTitle(comic, lang);
    const text = getShareText(comic, lang);
    const url = getShareUrl(comic);
    const shareText = title + " — " + text.replace(/\n/g, " ");

    if (navigator.share) {
      try {
        await navigator.share({ title, text: shareText, url });
        return;
      } catch (e) {
        if (e.name !== "AbortError") console.error("Share failed:", e);
      }
    }

    showShareModal(comic);
  }

  function buildShareModal(comic, lang) {
    const url = encodeURIComponent(getShareUrl(comic));
    const title = encodeURIComponent(getShareTitle(comic, lang));
    const text = encodeURIComponent(getShareText(comic, lang).replace(/\n/g, " "));
    const image = encodeURIComponent(comic.image);

    const platforms = [
      {
        name: "X",
        className: "share-platform-x",
        href: `https://twitter.com/intent/tweet?url=${url}&text=${title}%20%E2%80%94%20${text}`,
        svg: '<path d="M4 4h4.5l4.9 7 5.6-7H22l-6.6 8.4 6.6 9.6h-4.5l-5.3-7.7-6.1 7.7H2l7.2-9L4 4z"/>'
      },
      {
        name: "Facebook",
        className: "share-platform-fb",
        href: `https://www.facebook.com/sharer/sharer.php?u=${url}`,
        svg: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>'
      },
      {
        name: "WhatsApp",
        className: "share-platform-wa",
        href: `https://api.whatsapp.com/send?text=${text}%20${url}`,
