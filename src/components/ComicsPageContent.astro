                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="18" cy="5" r="3"></circle>
                  <circle cx="6" cy="12" r="3"></circle>
                  <circle cx="18" cy="19" r="3"></circle>
                  <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                  <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                </svg>
              </button>
            </div>
          </div>
          <div class="detail-tags"></div>
          <div class="detail-author">
            <div class="detail-author-avatar">\ud83c\udfa8</div>
            <div class="detail-author-info">
              <h4></h4>
              <p></p>
            </div>
          </div>
        </div>
      `;
      drawer.innerHTML = content;
    }

    drawer.querySelector(".detail-header-title").textContent = lang === "zh" ? "漫画详情" : "Comic Details";
    drawer.querySelector(".detail-image").src = comic.image;
    drawer.querySelector(".detail-image").alt = title;
    drawer.querySelector(".detail-text").innerHTML = text.replace(/\n/g, "<br/>");
    drawer.querySelector(".detail-title").textContent = title;
    drawer.querySelector(".detail-date").textContent = comic.date;
    const likeBtn = drawer.querySelector(".like-btn");
    likeBtn.className = `like-btn ${liked ? "liked" : ""}`;
    likeBtn.dataset.id = comic.id;
    likeBtn.innerHTML = `
      <svg width="18" height="18" viewBox="0 0 24 24" fill="${liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
      <span>${formatLikesLocal(comic.likes + (liked ? 1 : 0), lang)}</span>
    `;
    const shareBtn = drawer.querySelector(".share-btn");
    if (shareBtn) shareBtn.dataset.id = comic.id;

    const posterBtn = drawer.querySelector(".poster-btn");
    if (posterBtn) posterBtn.dataset.id = comic.id;

    drawer.querySelector(".detail-tags").innerHTML = (comic.tags[lang] || []).map(tag =>
      `<span class="detail-tag">${tag}</span>`
    ).join("");
    drawer.querySelector(".detail-author-info h4").textContent = lang === "zh" ? "小林" : "Xiaolin";
    drawer.querySelector(".detail-author-info p").textContent = lang === "zh" ? "用画笔记录生活的温暖瞬间" : "Capturing life's warm moments";

    const closeBtn = drawer.querySelector("#detail-close");
    if (closeBtn) {
      closeBtn.onclick = closeDetail;
    }

    const detailLikeBtn = drawer.querySelector(".like-btn");
    if (detailLikeBtn) {
      detailLikeBtn.onclick = (e) => {
        e.stopPropagation();
        const id = parseInt(detailLikeBtn.dataset.id || "0");
        const wasLiked = state.liked.has(id);
        if (wasLiked) {
          state.liked.delete(id);
        } else {
          state.liked.add(id);
          window.__likeComic(id);
        }

        const comic = getComicById(id);
        const lang = window.location.pathname.split("/")[1];
        const liked = state.liked.has(id);
        detailLikeBtn.className = `like-btn ${liked ? "liked" : ""}`;
        detailLikeBtn.innerHTML = `
          <svg width="18" height="18" viewBox="0 0 24 24" fill="${liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <span>${formatLikesLocal(comic.likes + (liked ? 1 : 0), lang)}</span>
        `;

        document.querySelectorAll(`.like-btn[data-id="${id}"]`).forEach(btn => {
          if (btn !== detailLikeBtn) {
            updateLikeBtn(btn, id);
          }
        });

        if (!wasLiked) {
          const display = drawer.querySelector('.detail-display');
          triggerLikeAnimation(display);
        }
      };
    }

    const detailShareBtn = drawer.querySelector(".share-btn");
    if (detailShareBtn) {
      detailShareBtn.onclick = (e) => {
        e.stopPropagation();
        const id = parseInt(detailShareBtn.dataset.id || "0");
        const comic = getComicById(id);
        if (comic) handleShare(comic);
      };
    }

    const detailPosterBtn = drawer.querySelector(".poster-btn");
    if (detailPosterBtn) {
      detailPosterBtn.onclick = (e) => {
        e.stopPropagation();
        const id = parseInt(detailPosterBtn.dataset.id || "0");
        const comic = getComicById(id);
        if (comic) showPosterModal(comic, lang);
      };
    }

    drawer.classList.add("visible");

    const backdrop = document.getElementById("backdrop");
    if (backdrop) {
      backdrop.classList.toggle("visible", state.detailComic !== null || state.tagDrawerOpen);
      if (backdrop.classList.contains("visible")) {
        backdrop.onclick = () => {
          if (state.tagDrawerOpen) {
            closeTagDrawer();
          }
          if (state.detailComic) {
            closeDetail();
          }
        };
      }
    }
  }

  function renderTagDrawer() {
    const tagDrawer = document.getElementById("tag-drawer");
    const backdrop = document.getElementById("backdrop");

    if (!tagDrawer || !backdrop) return;

    tagDrawer.classList.toggle("visible", state.tagDrawerOpen);
    backdrop.classList.toggle("visible", state.tagDrawerOpen || state.detailComic !== null);
    if (backdrop.classList.contains("visible")) {
      backdrop.onclick = () => {
        if (state.tagDrawerOpen) {
          closeTagDrawer();
        }
        if (state.detailComic) {
          closeDetail();
        }
      };
    }
  }

  function openDetail(comic) {
    state.detailComic = comic;
    renderDetailSheet();
    document.body.classList.add('scroll-locked');
  }

  function closeDetail() {
    state.detailComic = null;
    renderDetailSheet();
    renderTagDrawer();
    document.body.classList.remove('scroll-locked');
  }

  function openTagDrawer() {
    state.tagDrawerOpen = true;
    renderTagDrawer();
  }

  function closeTagDrawer() {
    state.tagDrawerOpen = false;
    renderTagDrawer();
  }

  function showPaginationElements(show) {
    document.querySelectorAll(".pagination").forEach(el => {
      el.style.display = show ? "" : "none";
    });
  }

  function renderTagPagination() {
    const tagPage = state.tagPage;
    const tagTotalPages = state.tagTotalPages;
    const lang = window.location.pathname.split("/")[1];

    const prevDisabled = tagPage <= 1;
    const nextDisabled = tagPage >= tagTotalPages;

    const arrowLeft = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"></path></svg>';
    const arrowRight = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"></path></svg>';

    const prevText = lang === "zh" ? "上一页" : "Previous";
    const nextText = lang === "zh" ? "下一页" : "Next";

    const prevHtml = prevDisabled
      ? `<span class="pagination-btn disabled">${arrowLeft} ${prevText}</span>`
      : `<a class="pagination-btn" data-direction="prev">${arrowLeft} ${prevText}</a>`;

    const infoHtml = `<span class="pagination-info">${lang === "zh" ? `第 ${tagPage} / ${tagTotalPages} 页` : `Page ${tagPage} / ${tagTotalPages}`}</span>`;

    const nextHtml = nextDisabled
      ? `<span class="pagination-btn disabled">${nextText} ${arrowRight}</span>`
      : `<a class="pagination-btn" data-direction="next">${nextText} ${arrowRight}</a>`;

    document.querySelectorAll(".pagination").forEach(el => {
      el.innerHTML = prevHtml + infoHtml + nextHtml;
    });
  }

  async function loadTagPage(page) {
    if (!state.activeTag) return;
    state.tagPage = page;
    const lang = window.location.pathname.split("/")[1];
    try {
      const result = await window.__getComicsByTag(state.activeTag, lang, page, 20);
      state.tagTotal = result.total;
      state.tagTotalPages = Math.ceil(result.total / 20) || 1;
      COMICS.length = 0;
      COMICS.push(...result.items);
      rebuildComicsById(COMICS);
      renderAll();
      renderTagPagination();
    } catch (e) {
      console.error("Tag page load failed:", e);
    }
  }

  function setupTagFilter() {
    const tagFilter = document.getElementById("tag-filter");
    const tagDrawerGrid = document.getElementById("tag-drawer-grid");
    const moreBtn = document.getElementById("more-btn");

    async function handleTagClick(tag) {
      state.activeTag = tag;
      closeTagDrawer();

      if (tag === "") {
        COMICS.length = 0;
        COMICS.push(...SSR_COMICS);
        state.isTagMode = false;
        rebuildComicsById(COMICS);
        document.querySelectorAll(".pagination").forEach((el, i) => {
          el.innerHTML = SSR_PAGINATION[i] || "";
        });
        renderAll();
        showPaginationElements(true);
      } else {
        state.isTagMode = true;
        state.tagPage = 1;
        const lang = window.location.pathname.split("/")[1];
        try {
          const result = await window.__getComicsByTag(tag, lang, 1, 20);
          state.tagTotal = result.total;
          state.tagTotalPages = Math.ceil(result.total / 20) || 1;
          COMICS.length = 0;
          COMICS.push(...result.items);
          rebuildComicsById(COMICS);
          renderAll();
          renderTagPagination();
          showPaginationElements(true);
        } catch (e) {
          console.error("Tag filter failed:", e);
        }
      }
    }

    [tagFilter, tagDrawerGrid].forEach(container => {
      if (!container) return;
      container.addEventListener("click", (e) => {
        const btn = (e.target).closest(".tag-btn");
        if (btn) handleTagClick(btn.dataset.tag);
      });
    });

    if (moreBtn) {
      moreBtn.addEventListener("click", openTagDrawer);
    }
  }

  function setupWaterfallClicks() {
    const waterfall = document.getElementById("waterfall");
    if (!waterfall) return;

    waterfall.addEventListener("click", (e) => {
      const target = e.target;
      const likeBtn = target.closest(".like-btn");

      if (likeBtn) {
        const id = parseInt(likeBtn.dataset.id || "0");
        const wasLiked = state.liked.has(id);
        if (wasLiked) {
          state.liked.delete(id);
        } else {
          state.liked.add(id);
          window.__likeComic(id);
        }
        updateLikeBtn(likeBtn, id);

        if (!wasLiked) {
          const card = likeBtn.closest('.waterfall-card');
          triggerLikeAnimation(card);
        }

        if (state.detailComic && state.detailComic.id === id) {
          renderDetailSheet();
        }
        return;
      }

      const shareBtn = target.closest(".share-btn");
      if (shareBtn) {
        e.stopPropagation();
        const id = parseInt(shareBtn.dataset.id || "0");
        const comic = getComicById(id);
        if (comic) handleShare(comic);
        return;
      }

      const card = target.closest(".waterfall-card");
      if (card) {
        const id = parseInt(card.dataset.comicId || "0");
        const comic = getComicById(id);
        if (comic) openDetail(comic);
      }
    });
  }

  function setupCarouselClicks() {
    const carousel = document.getElementById("carousel");
    if (!carousel) return;

    carousel.addEventListener("click", (e) => {
      const target = e.target;
      const likeBtn = target.closest(".like-btn");

      if (likeBtn) {
        const id = parseInt(likeBtn.dataset.id || "0");
        const wasLiked = state.liked.has(id);
        if (wasLiked) {
          state.liked.delete(id);
        } else {
          state.liked.add(id);
          window.__likeComic(id);
        }

        const cards = carousel.querySelectorAll(".carousel-card");
        let cardWithLike = null;
        cards.forEach(card => {
          const cardId = parseInt(card.dataset.id || "0");
          const btn = card.querySelector(".like-btn");
          if (btn && cardId === id) {
            const comic = getComicById(id);
            const lang = window.location.pathname.split("/")[1];
            const liked = state.liked.has(id);
            btn.classList.toggle("liked", liked);
            btn.innerHTML = `
              <svg width="15" height="15" viewBox="0 0 24 24" fill="${liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
              <span>${formatLikesLocal(comic.likes + (liked ? 1 : 0), lang)}</span>
            `;
            cardWithLike = card;
          }
        });

        if (!wasLiked && cardWithLike) {
          triggerLikeAnimation(cardWithLike);
        }

        return;
      }

      const card = target.closest(".carousel-card");
      if (card) {
        const id = parseInt(card.dataset.id || "0");
        const comic = getComicById(id);
        if (comic) openDetail(comic);
      }
    });

    function checkHash() {
      const hash = window.location.hash;
      if (hash.startsWith("#comic-")) {
        const id = parseInt(hash.replace("#comic-", ""));
        const comic = getComicById(id);
        if (comic) openDetail(comic, false);
      }
    }
    checkHash();
    window.addEventListener("hashchange", checkHash);
  }

  function setupTagPagination() {
    document.querySelectorAll(".pagination").forEach(el => {
      el.addEventListener("click", (e) => {
        if (!state.isTagMode) return;
        const btn = e.target.closest(".pagination-btn");
        if (!btn || btn.classList.contains("disabled")) return;
        const direction = btn.dataset.direction;
        if (!direction) return;
        const newPage = direction === "prev" ? state.tagPage - 1 : state.tagPage + 1;
        loadTagPage(newPage);
      });
    });
  }

  renderAll();
  showPaginationElements(true);
  setupTagFilter();
  setupWaterfallClicks();
  setupCarouselClicks();
  setupTagPagination();
})();
</script>
