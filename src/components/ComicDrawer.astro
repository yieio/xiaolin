---
import type { Comic } from "@/lib/api";
import { t, formatLikes } from "@/lib/i18n";
import type { Locale } from "@/lib/i18n";

export interface Props {
  lang: Locale;
  comic: Comic;
  visible?: boolean;
}

const { lang, comic, visible = false } = Astro.props;
const title = lang === "zh" ? comic.title.zh : comic.title.en;
const text = lang === "zh" ? comic.text.zh : comic.text.en;
---

<div class="detail-sheet ${visible ? 'visible' : ''}" id="comic-drawer">
  <div class="detail-header">
    <div class="detail-header-title">{t("comic.details", lang)}</div>
    <button class="detail-close" id="detail-close" aria-label={t("comic.close", lang)}>×</button>
  </div>
  <div class="detail-content">
    <div class="card-stack">
      <div class="card-stack-shadow-1"></div>
      <div class="card-stack-shadow-2"></div>
      <div class="detail-display">
        <img class="detail-image" src={comic.image} alt={title} draggable="false" />
        <p class="detail-text" set:html={text.replace(/\n/g, "<br/>")}></p>
      </div>
    </div>
    <div class="detail-meta">
      <div>
        <div class="detail-title">{title}</div>
        <div class="detail-date">{comic.date}</div>
      </div>
      <div class="detail-actions">
        <button class="poster-btn" data-action="poster" data-id={comic.id} title={t("comic.sharePoster", lang)}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <polyline points="21 15 16 10 5 21"></polyline>
          </svg>
        </button>
        <button class="like-btn" data-action="like" data-id={comic.id}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <span>{formatLikes(comic.likes, lang)}</span>
        </button>
      </div>
    </div>
    <div class="detail-tags">
      {(comic.tags[lang] || []).map((tag) => (
        <span class="detail-tag">{tag}</span>
      ))}
    </div>
    <div class="detail-author">
      <div ><img class="detail-author-avatar" src="/imgs/xiaolin.png" alt={t("comic.authorName", lang)}></div>
      <div class="detail-author-info">
        <h4>{t("comic.authorName", lang)}</h4>
        <p>{t("comic.authorBio", lang)}</p>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .detail-sheet {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #ffffff;
    z-index: 210;
    display: flex;
    flex-direction: column;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.34, 1.2, 0.64, 1), visibility 0.35s;
    visibility: hidden;
    pointer-events: none;
  }

  .detail-sheet.visible {
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    .detail-sheet {
      top: 0;
      bottom: 0;
      left: auto;
      right: 0;
      width: 480px;
      height: 100vh;
      transform: translateX(100%);
      border-left: 1px solid #f0f0f0;
    }

    .detail-sheet.visible {
      transform: translateX(0);
    }
  }

  .detail-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    background: #ffffff;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
    border-radius: inherit;
  }

  .detail-header-title {
    font-family: 'Noto Sans SC', sans-serif;
    font-weight: 500;
    font-size: 14px;
    color: var(--text-primary);
    letter-spacing: 0.03em;
  }

  .detail-close {
    background: none;
    border: none;
    font-size: 24px;
    color: var(--text-muted);
    cursor: pointer;
    line-height: 1;
    padding: 0 4px;
    transition: color 0.2s;
  }

  .detail-close:hover {
    color: var(--text-primary);
  }

  .detail-content {
    flex: 1;
    overflow-y: auto;
    padding: 18px 20px 36px;
  }

  .card-stack {
    position: relative;
    margin: 0 auto;
    margin-bottom: 18px;
    max-width: 320px;
    
  }

  .card-stack-shadow-1 {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 16px;
    background: #ffffff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border: 1px solid #f0f0f0;
    transform: translateY(-15px) scale(0.96) rotate(4deg);
    transform-origin: center center;
  }

  .card-stack-shadow-2 {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 16px;
    background: #ffffff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border: 1px solid #f0f0f0;
    transform: translateY(-28px) scale(0.92) rotate(-3deg);
    transform-origin: center center;
  }

  .detail-display {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 12px 12px 14px;
    overflow: hidden;
    border-radius: 16px;
    background: #ffffff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border: 1px solid #f0f0f0;
  }

  .detail-image {
    width: 100%;
    height: auto;
    aspect-ratio: 2/3;
    object-fit: cover;
    border-radius: 12px;
    position: relative;
    z-index: 1;
    display: block;
  }

  .detail-text {
    font-family: 'Noto Serif SC', serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1.6;
    letter-spacing: 0.03em;
    color: var(--text-primary);
    white-space: pre-line;
    position: relative;
    z-index: 1;
    text-align: left;
  }

  .detail-meta {
    margin-top: 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .detail-title {
    font-family: 'Noto Serif SC', serif;
    font-weight: 500;
    font-size: 15px;
    color: var(--text-primary);
    letter-spacing: 0.03em;
  }

  .detail-date {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .detail-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 14px;
  }

  .detail-tag {
    font-size: 10px;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
    padding: 4px 12px;
    border-radius: 14px;
    border: 1px solid #e8e8e8;
    background: #f5f5f5;
  }

  .detail-author {
    margin-top: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px;
    border-radius: 12px;
    background: #fafafa;
    border: 1px solid #f0f0f0;
  }

  .detail-author-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .detail-author-info h4 {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 0.03em;
  }

  .detail-author-info p {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.03em;
    margin-top: 2px;
  }

  .detail-actions {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .poster-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 4px 6px;
    border-radius: 8px;
    transition: color 0.2s ease, transform 0.15s ease;
  }

  .poster-btn:active {
    transform: scale(0.9);
    color: var(--text-secondary);
  }

  .like-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    padding: 4px 6px;
    transition: color 0.2s ease, transform 0.15s ease;
  }

  .like-btn:active {
    transform: scale(0.9);
  }

  .like-btn.liked {
    color: var(--heart-active);
  }
</style>
