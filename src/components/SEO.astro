---
import { getAlternateLang } from "@lib/i18n";
import type { Locale } from "@lib/i18n";

export interface Props {
  lang: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  type?: "website" | "article";
  publishedTime?: string;
  tags?: string[];
}

const {
  lang,
  title,
  description,
  ogImage,
  canonicalURL,
  type = "website",
  publishedTime,
  tags,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "http://localhost:4321";
const currentPath = Astro.url.pathname;
const defaultTitle = "Xiaolin Comics";
const defaultDesc =
  lang === "zh"
    ? "每天一幅小林漫画，用幽默与生活对话"
    : "Daily dose of humor and life through Xiaolin's unique illustrations";

const resolvedTitle = title || defaultTitle;
const resolvedDesc = description || defaultDesc;

// Full page title
const pageTitle =
  title && title !== defaultTitle ? `${title} — Xiaolin Comics` : defaultTitle;

const altLang = getAlternateLang(lang);
const altPath = currentPath.replace(new RegExp(`^/${lang}`), `/${altLang}`);
const altUrl = `${siteUrl}${altPath}`;
const canonical = canonicalURL || `${siteUrl}${currentPath}`;

// JSON-LD structured data
const structuredData: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "CreativeWork" : "WebSite",
  name: resolvedTitle,
  description: resolvedDesc,
  url: canonical,
  ...(type === "article" && {
    image: ogImage,
    datePublished: publishedTime,
    ...(tags?.length && { keywords: tags.join(", ") }),
  }),
};
---

<title>{pageTitle}</title>
<meta name="description" content={resolvedDesc} />

<!-- Canonical -->
<link rel="canonical" href={canonical} />

<!-- Hreflang -->
<link rel="alternate" hreflang={lang} href={canonical} />
<link rel="alternate" hreflang={altLang} href={altUrl} />
<link rel="alternate" hreflang="x-default" href={`${siteUrl}${currentPath.replace(new RegExp(`^/${lang}`), "/en")}`} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={resolvedDesc} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content="Xiaolin Comics" />
<meta property="og:locale" content={lang === "zh" ? "zh_CN" : "en_US"} />
{
  ogImage && (
    <>
      <meta property="og:image" content={ogImage} />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
    </>
  )
}

<!-- Twitter Card -->
<meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={resolvedDesc} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)}>
</script>
