---
import type { Comic } from "@/lib/api";
import { t, formatLikes } from "@/lib/i18n";
import type { Locale } from "@/lib/i18n";

interface Props {
  comics: Comic[];
  lang: Locale;
}

const { comics, lang } = Astro.props;
---

<div class="inner-container">
  <div class="featured-section">
    <div class="section-label">
      <h2>{t("home.featured", lang)}</h2>
      <span class="swipe-hint">{t("home.swipeHint", lang)}</span>
    </div>
  </div>
</div>

<div class="carousel-container" id="carousel">
  {comics.map((comic) => (
    <div class="carousel-card" data-id={comic.id} style={{ background: comic.color }}>
      <img 
        class="carousel-image" 
        src={comic.image} 
        alt={lang === "zh" ? comic.title.zh : comic.title.en}
        loading="lazy"
        draggable="false"
      />
      <p class="carousel-text">{lang === "zh" ? comic.text.zh : comic.text.en}</p>
      <div class="carousel-meta">
        <div class="carousel-tags">
          {(comic.tags[lang] || []).slice(0, 2).map((tag) => (
            <span class="carousel-tag">{tag}</span>
          ))}
        </div>
        <button class="like-btn" data-action="like" data-id={comic.id}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <span>{formatLikes(comic.likes, lang)}</span>
        </button>
      </div>
    </div>
  ))}
</div>

<div class="inner-container">
  <div class="dot-indicators" id="dots">
    {comics.map((_, i) => (
      <div class="dot" data-index={i}></div>
    ))}
  </div>
</div>

<script is:inline>
(function() {
  let state = {
    carouselIndex: 0,
    carouselDragging: false,
    carouselDragDx: 0,
    carouselLocked: false,
    liked: new Set()
  };
  let autoplayTimer = null;
  const container = document.getElementById('carousel');
  const cards = container ? Array.from(container.querySelectorAll('.carousel-card')) : [];
  const dots = Array.from(document.querySelectorAll('#dots .dot'));
  const total = cards.length;

  function renderCarousel() {
    dots.forEach((dot, i) => {
      dot.classList.toggle('active', i === state.carouselIndex);
    });

    cards.forEach((card, i) => {
      const diff = (i - state.carouselIndex + total) % total;
      let transform = '';
      let opacity = 1;
      let zIndex = 0;
      let pointerEvents = 'auto';

      const dx = state.carouselDragging && diff === 0 ? state.carouselDragDx : 0;
      const dragRot = state.carouselDragging && diff === 0 ? state.carouselDragDx * 0.03 : 0;

      if (state.carouselDragging && diff === 0) {
        card.style.transition = 'none';
      } else {
        card.style.transition = 'transform 0.4s cubic-bezier(0.34, 1.2, 0.64, 1), opacity 0.4s';
      }

      if (diff === 0) {
        transform = `translate(calc(-50% + ${dx}px), -50%) scale(1) rotate(${dragRot}deg)`;
        zIndex = 100;
        opacity = 1;
        pointerEvents = 'auto';
      } else if (diff === 1) {
        transform = 'translate(-50%, calc(-50% - 15px)) scale(0.96) rotate(4deg)';
        zIndex = 99;
        opacity = 1;
        pointerEvents = 'auto';
      } else if (diff === 2) {
        transform = 'translate(-50%, calc(-50% - 28px)) scale(0.92) rotate(-3deg)';
        zIndex = 98;
        opacity = 1;
        pointerEvents = 'auto';
      } else if (diff === 3) {
        transform = 'translate(-50%, calc(-50% - 40px)) scale(0.88) rotate(2deg)';
        zIndex = 97;
        opacity = 1;
        pointerEvents = 'auto';
      } else if (diff === total - 1) {
        transform = 'translate(calc(-50% - 150px), -50%) scale(0.9) rotate(-10deg)';
        zIndex = 101;
        opacity = 0;
        pointerEvents = 'none';
      } else {
        transform = 'translate(-50%, calc(-50% - 50px)) scale(0.84) rotate(0deg)';
        zIndex = 0;
        opacity = 0;
        pointerEvents = 'none';
      }

      card.style.transform = transform;
      card.style.zIndex = zIndex;
      card.style.opacity = opacity;
      card.style.pointerEvents = pointerEvents;
    });
  }

  function startAutoPlay() {
    stopAutoPlay();
    autoplayTimer = setInterval(() => {
      if (!state.carouselDragging) {
        state.carouselIndex = (state.carouselIndex + 1) % total;
        renderCarousel();
      }
    }, 3500);
  }

  function stopAutoPlay() {
    if (autoplayTimer) {
      clearInterval(autoplayTimer);
      autoplayTimer = null;
    }
  }

  let startX = 0, startY = 0;

  function startDrag(x, y) {
    state.carouselDragging = true;
    state.carouselLocked = false;
    state.carouselDragDx = 0;
    startX = x;
    startY = y;
    stopAutoPlay();
  }

  function moveDrag(x, y, e) {
    if (!state.carouselDragging) return;
    const dx = x - startX;
    const dy = y - startY;
    
    if (!state.carouselLocked && Math.abs(dx) > 5 && Math.abs(dx) > Math.abs(dy)) {
      state.carouselLocked = true;
    }
    
    if (state.carouselLocked) {
      if (e && e.cancelable) e.preventDefault();
      state.carouselDragDx = dx;
      renderCarousel();
    }
  }

  function endDrag() {
    if (!state.carouselDragging) return;
    state.carouselDragging = false;
    
    if (state.carouselDragDx < -40) {
      state.carouselIndex = (state.carouselIndex + 1) % total;
    } else if (state.carouselDragDx > 40) {
      state.carouselIndex = (state.carouselIndex - 1 + total) % total;
    }
    
    state.carouselDragDx = 0;
    renderCarousel();
    startAutoPlay();
  }

  if (container) {
    container.addEventListener('touchstart', (e) => {
      startDrag(e.touches[0].clientX, e.touches[0].clientY);
    }, { passive: true });

    container.addEventListener('touchmove', (e) => {
      moveDrag(e.touches[0].clientX, e.touches[0].clientY, e);
    }, { passive: false });

    container.addEventListener('touchend', endDrag);

    container.addEventListener('mousedown', (e) => {
      startDrag(e.clientX, e.clientY);
    });

    window.addEventListener('mousemove', (e) => {
      moveDrag(e.clientX, e.clientY, e);
    });

    window.addEventListener('mouseup', endDrag);
  }

  renderCarousel();
  startAutoPlay();
})();
</script>

<style>
.featured-section {
  margin-top: 24px;
  padding: 0 20px;
}

.section-label {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20px;
}

.section-label h2 {
  font-family: 'Noto Serif SC', serif;
  font-weight: 500;
  font-size: 17px;
  color: var(--text-primary);
  letter-spacing: 0.03em;
}

.section-label .swipe-hint {
  font-size: 10px;
  color: var(--text-faint);
  letter-spacing: 0.08em;
}

.carousel-container {
  position: relative;
  height: 560px;
  touch-action: pan-y;
  cursor: grab;
}

@media (min-width: 768px) {
  .carousel-container {
    height: 620px;
  }
}

.carousel-container:active {
  cursor: grabbing;
}

.carousel-card {
  position: absolute;
  top: 50%;
  left: 50%;
  width: calc(100% - 20px);
  max-width: 320px;
  padding: 12px 12px 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  border: 1px solid #f0f0f0;
  transform-origin: center center;
  transition: transform 0.4s cubic-bezier(0.34, 1.2, 0.64, 1), opacity 0.4s;
  overflow: hidden;
}

@media (min-width: 768px) {
  .carousel-card {
    max-width: 360px;
    padding: 14px 14px 18px;
  }
}

.carousel-image {
  width: 100%;
  height: auto;
  aspect-ratio: 2/3;
  object-fit: cover;
  border-radius: 12px;
  position: relative;
  z-index: 1;
  display: block;
  -webkit-user-drag: none;
}

.carousel-text {
  font-family: 'Noto Serif SC', serif;
  font-weight: 500;
  font-size: 14px;
  line-height: 1.6;
  letter-spacing: 0.03em;
  color: var(--text-primary);
  white-space: pre-line;
  position: relative;
  z-index: 1;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.carousel-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.carousel-tags {
  display: flex;
  gap: 6px;
  flex-wrap: nowrap;
}

.carousel-tag {
  font-size: 9px;
  color: var(--text-muted);
  letter-spacing: 0.06em;
  background: #f5f5f5;
  padding: 4px 12px;
  border-radius: 8px;
  border: none;
  white-space: nowrap;
  font-weight: 500;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  font-size: 12px;
  color: var(--text-muted);
  letter-spacing: 0.06em;
  padding: 4px 8px;
  border-radius: 8px;
  transition: all 0.2s ease, transform 0.15s ease;
  font-weight: 500;
}

.like-btn:active {
  transform: scale(0.9);
}

.like-btn.liked {
  color: var(--heart-active);
}

.dot-indicators {
  display: flex;
  justify-content: center;
  gap: 6px;
  margin-top: 24px;
}

.dot {
  height: 5px;
  width: 5px;
  border-radius: 4px;
  background: #d4c7b5;
  transition: all 0.3s ease;
  cursor: pointer;
}

.dot.active {
  width: 18px;
  background: var(--accent-primary);
}
</style>
